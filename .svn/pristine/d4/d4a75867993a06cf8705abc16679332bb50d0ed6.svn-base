using System.Reflection;

namespace System.Data.Odbc;

/// <summary>
/// Represents a parameter to an OdbcCommand.
/// </summary>
[Obfuscation(Exclude = true, ApplyToMembers = false)]
public class OdbcParameter : EmulatedDbParameter
{
    public OdbcParameter()
    {
    }

    public OdbcParameter(string parameterName, object? value)
    {
        ParameterName = parameterName;
        Value = value;
    }
}
